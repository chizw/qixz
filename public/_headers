# Cloudflare Pages 缓存头配置
# 详细规则参考：https://developers.cloudflare.com/pages/configuration/headers/

# Nuxt 构建产物（JS/CSS/字体等，文件名包含内容哈希），可长期缓存
/_nuxt/*
  Cache-Control: public, max-age=31536000, immutable

# public/assets 下的静态样式与 XSL 模板
/assets/*
  Cache-Control: public, max-age=604800

# 站点图标与图片（无内容哈希，使用中等缓存）
/avatar.avif
  Cache-Control: public, max-age=604800

/favicon.svg
  Cache-Control: public, max-age=604800, must-revalidate

/mps.png
  Cache-Control: public, max-age=604800

# 经常更新的 Feed、OPML、预渲染 API，不缓存
/atom.xml
  Cache-Control: public, max-age=0, must-revalidate

/qxz.opml
  Cache-Control: public, max-age=0, must-revalidate

/api/stats
  Cache-Control: public, max-age=0, must-revalidate

# 默认：HTML 页面等动态内容不缓存，每次重新验证
/*
  Cache-Control: public, max-age=0, must-revalidate
